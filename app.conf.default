# WhisperServer runtime configuration
#
# The server reads app.conf first. If app.conf does not exist, this file is used.
# Copy this file to app.conf for local changes. Keep secrets, API keys, and
# production-only overrides out of app.conf.default.
#
# Supported syntax:
# - KEY=value
# - Blank lines, lines starting with #, and lines starting with ; are ignored.
# - Boolean values accept common truthy strings such as true, yes, on, and 1.
# - List values, such as GEMINI_API_KEYS, can be JSON arrays or comma-separated
#   values. JSON array format is recommended.


###############################################################################
# Server
###############################################################################

# HTTP port used by the server.
# Example: PORT=8000 starts the app at http://localhost:8000
PORT=8000

# Runtime mode.
#
# PRODUCTION:
# - Uses .run/whisper.db.
# - Uses the normal Gemini/Whisper processing path.
#
# DEV:
# - Uses .run/whisper.dev.db.
# - Uses a different JWT issuer suffix, so DEV and PRODUCTION sessions cannot
#   authenticate each other.
# - Uses stubbed transcription/refinement/PDF extraction flows for local testing.
#   Audio transcription takes about 20 seconds, refinement takes about 10 seconds.
#
# Allowed values: PRODUCTION, DEV
RUN_MODE=PRODUCTION


###############################################################################
# Uploads and job execution
###############################################################################

# Maximum upload size per file, in megabytes.
# Must be greater than 0. The server rejects larger uploads before processing.
MAX_UPLOAD_SIZE_MB=512

# Optional upload throttle, in kilobytes per second.
# 0 disables throttling. Use a positive value to slow incoming uploads.
UPLOAD_RATE_LIMIT_KBPS=0

# Maximum wall-clock time for an audio transcription/refinement job, in seconds.
# Must be greater than 0. DEV mode also uses this timeout around stubbed tasks.
JOB_TIMEOUT_SEC=3600

# Queue mode for audio transcription and follow-up refinement/PDF work.
#
# false:
# - Uses one shared worker queue.
#
# true:
# - Splits transcription and refinement/PDF extraction into separate queues.
# - Useful when long refinement/PDF jobs should not block new transcriptions.
SPLIT_TRANSCRIBE_REFINE_QUEUE=false


###############################################################################
# Gemini
###############################################################################

# Gemini model used for transcript refinement and PDF extraction.
# Must not be empty. Pick a model that supports the configured response schema
# and thinking configuration used by the application.
GEMINI_MODEL=gemini-flash-lite-latest

# Gemini API keys used for refinement/PDF extraction.
#
# The server rotates across configured keys and applies cooldown/backoff when a
# key fails. Leave [] when Gemini features should be unavailable in PRODUCTION.
# DEV mode can run without real Gemini keys because processing is stubbed.
#
# Recommended JSON array format:
# GEMINI_API_KEYS=["key1","key2"]
#
# Multi-line JSON arrays are also supported:
# GEMINI_API_KEYS=[
#   "key1",
#   "key2"
# ]
GEMINI_API_KEYS=[]


###############################################################################
# PDF processing
###############################################################################

# Maximum page count accepted for a single PDF job.
# Must be greater than 0.
PDF_MAX_PAGES=300

# Maximum number of rendered PDF pages sent to Gemini in one request.
# Must be greater than 0 and less than or equal to PDF_MAX_PAGES.
PDF_MAX_PAGES_PER_REQUEST=80

# Render DPI for converting PDF pages into JPEG images before Gemini extraction.
# Higher values improve OCR/detail but increase memory, disk, and request size.
# Must be greater than 0.
PDF_RENDER_DPI=144

# Per-batch timeout for PDF extraction requests, in seconds.
# Must be greater than 0.
PDF_BATCH_TIMEOUT_SEC=180

# Maximum total rendered image bytes allowed for a PDF job.
# Must be greater than 0. The default is 200 MiB.
PDF_MAX_RENDERED_IMAGE_BYTES=209715200

# Maximum character count from prior extracted PDF content used as consistency
# context for later PDF batches. Must be greater than 0.
PDF_CONSISTENCY_CONTEXT_MAX_CHARS=6000

# External Poppler tool used to inspect PDF metadata/page counts.
# Use an absolute path if the binary is not available on PATH.
PDF_TOOL_PDFINFO=pdfinfo

# External Poppler tool used to render PDF pages to images.
# Use an absolute path if the binary is not available on PATH.
PDF_TOOL_PDFTOPPM=pdftoppm


###############################################################################
# Authentication and sessions
###############################################################################

# JWT signing secret.
#
# Empty value:
# - The server generates an ephemeral secret on each process start.
# - All existing sessions become invalid after restart.
#
# Production:
# - Set a long random value and keep it stable across restarts.
# - Do not commit the real value.
JWT_SECRET=

# JWT issuer base value.
# In DEV mode the server automatically appends ":dev" so DEV sessions and
# PRODUCTION sessions are not accepted by each other.
JWT_ISSUER=whisperserver

# JWT/session lifetime in hours.
# Must be greater than 0.
JWT_EXP_HOURS=24

# Whether the auth cookie is marked Secure.
#
# false:
# - Allows local HTTP development.
#
# true:
# - Required for HTTPS production deployments.
# - Browsers will not send Secure cookies over plain HTTP.
AUTH_COOKIE_SECURE=false
